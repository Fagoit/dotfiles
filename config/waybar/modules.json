    "on-click": "ghostty --class=local.bluetui -e bluetui"
  },
  "custom/brightness": {
    "format": "ï†…",
    "on-click": "walker -t menus -m menus:brightness --maxheight 350 --minwidth 50 -N"
  },
  "custom/filemanager": {
    "format": "ïپ¼",
    "on-click": "nautilus",
    "tooltip-format": "Open Filemanager"
  },
  "custom/screenrecord": {
    "exec": "screenrecord-status",
    "return-type": "json",
    "signal": 8,
    "interval": 1,
    "on-click": "screenrecord output"
  }
}

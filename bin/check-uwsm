#!/bin/bash

# Check if Hyprland is running under UWSM (systemd sessions only).
# On non-systemd (OpenRC/elogind) sessions, uwsm is not available and not required.

if ! command -v uwsm >/dev/null 2>&1; then
    exit 0
fi

if ! uwsm check is-active; then
    notify-send \
        --app-name="UWSM Warning" \
        --urgency=critical \
        --expire-time=0 \
        --icon=dialog-warning \
        "UWSM ERROR" \
        "Hyprland is not running under UWSM.\nPlease reboot and select 'Hyprland (uwsm managed)' \nat login."
fi

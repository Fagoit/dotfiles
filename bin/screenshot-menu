#!/bin/bash
set -e

choice=$(printf '%s\n' \
  "Area to clipboard" \
  "Area to file" \
  "Fullscreen to clipboard" \
  "Fullscreen to file" | rofi -dmenu -p "Screenshot")

case "$choice" in
  "Area to clipboard")
    maim -s | xclip -selection clipboard -t image/png
    notify-send "Copied Area"
    ;;
  "Area to file")
    mkdir -p "$HOME/Pictures"
    maim -s "$HOME/Pictures/$(date +%Y-%m-%d_%H-%M-%S).png"
    notify-send "Saved Screenshot"
    ;;
  "Fullscreen to clipboard")
    maim | xclip -selection clipboard -t image/png
    notify-send "Copied Fullscreen"
    ;;
  "Fullscreen to file")
    mkdir -p "$HOME/Pictures"
    maim "$HOME/Pictures/$(date +%Y-%m-%d_%H-%M-%S).png"
    notify-send "Saved Fullscreen"
    ;;
esac

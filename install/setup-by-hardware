#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/lib/helpers.sh"
source "$SCRIPT_DIR/lib/backup.sh"
DOTFILES_DIR="$HOME/.local/share/dotfiles"

log_info "Configuring hardware-specific settings..."

HARDWARE=$(detect_hardware_type)
if [ "$HARDWARE" = "laptop" ]; then
  spinner "Installing brightnessctl..." yay --noconfirm -S brightnessctl
  log_detail "Detected laptop hardware"
else
  spinner "Installing ddcutil..." yay --noconfirm -S ddcutil
  log_detail "Detected desktop hardware"
fi

if [ -f "$DOTFILES_DIR/default/xbindkeys/xbindkeysrc" ]; then
  [ -f "$HOME/.xbindkeysrc" ] && backup_file "$HOME/.xbindkeysrc"
  cp "$DOTFILES_DIR/default/xbindkeys/xbindkeysrc" "$HOME/.xbindkeysrc"
  log_success "X11 keybindings installed"
fi

if command -v xrandr &>/dev/null; then
  log_detail "Monitor layout is managed by X11/xrandr; keep custom xrandr commands in your WindowMaker session if needed"
fi

log_success "Hardware-specific configuration applied"
